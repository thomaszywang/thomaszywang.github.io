<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #f7f6f3;
    --surface: #ffffff;
    --border: #e8e4dc;
    --border-light: #f0ede6;
    --text-primary: #1a1916;
    --text-secondary: #6b6760;
    --text-tertiary: #a09c96;
    --accent: #b5651d;
    --accent-light: #f5ede3;
    --accent-hover: #9a5518;
    --sidebar-w: 280px;
    --nav-h: 56px;
    --radius: 10px;
    --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.04);
  }

  html { font-size: 15px; scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text-primary);
    min-height: 100vh;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    height: var(--nav-h);
    background: rgba(247,246,243,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center;
    padding: 0 2rem;
    z-index: 100;
    animation: fadeDown 0.5s ease both;
  }

  .nav-name {
    font-family: 'Crimson Pro', serif;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text-primary);
    white-space: nowrap;
    margin-right: auto;
  }

  .nav-links {
    display: flex; gap: 2px;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 5px 14px;
    border-radius: 20px;
    transition: all 0.2s;
    letter-spacing: 0.01em;
  }

  .nav-links a:hover, .nav-links a.active {
    background: var(--surface);
    color: var(--text-primary);
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
  }

  .nav-links a.active {
    font-weight: 500;
  }

  /* ── LAYOUT ── */
  .layout {
    max-width: 1060px;
    margin: 0 auto;
    padding: calc(var(--nav-h) + 2.5rem) 2rem 4rem;
    display: grid;
    grid-template-columns: var(--sidebar-w) 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    position: sticky;
    top: calc(var(--nav-h) + 1.5rem);
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .profile-img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: var(--radius);
    overflow: hidden;
    background: linear-gradient(145deg, #d4c5b0, #c2b49a);
    margin-bottom: 1.25rem;
    box-shadow: var(--shadow);
    position: relative;
  }

  .profile-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .profile-img-placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 8px;
  }

  .profile-img-placeholder .lens {
    width: 64px; height: 64px;
    border-radius: 50%;
    border: 3px solid rgba(255,255,255,0.5);
    display: flex; align-items: center; justify-content: center;
    position: relative;
  }

  .profile-img-placeholder .lens::after {
    content: '';
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    border: 2px solid rgba(255,255,255,0.4);
  }

  .profile-img-placeholder span {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.7);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.05em;
  }

  .profile-name {
    font-family: 'Crimson Pro', serif;
    font-size: 1.55rem;
    font-weight: 600;
    text-align: center;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .profile-role {
    text-align: center;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 500;
    margin: 4px 0 3px;
    letter-spacing: 0.02em;
  }

  .profile-affil {
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.8rem;
  }

  .social-row {
    display: flex; justify-content: center; gap: 10px;
    margin: 1rem 0 1.25rem;
  }

  .social-btn {
    width: 32px; height: 32px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.75rem;
    transition: all 0.2s;
    cursor: pointer;
  }

  .social-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-light);
  }

  .social-btn svg { width: 15px; height: 15px; fill: currentColor; }

  .sidebar-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.1rem;
    margin-top: 0.85rem;
  }

  .sidebar-card-title {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 0.65rem;
  }

  .interest-item {
    font-size: 0.82rem;
    color: var(--text-secondary);
    padding: 4px 0;
    border-bottom: 1px solid var(--border-light);
    display: flex; align-items: center; gap: 7px;
    line-height: 1.4;
  }

  .interest-item:last-child { border-bottom: none; }

  .interest-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--accent); flex-shrink: 0;
  }

  /* ── MAIN ── */
  .main {
    animation: fadeUp 0.6s 0.2s ease both;
  }

  /* sections */
  .section {
    display: none;
  }

  .section.active {
    display: block;
    animation: fadeIn 0.3s ease both;
  }

  /* about */
  .section-heading {
    font-family: 'Crimson Pro', serif;
    font-size: 1.7rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .about-text p {
    font-size: 0.93rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 0.9rem;
  }

  .about-text p:last-child { margin-bottom: 0; }

  .about-text a { color: var(--accent); text-decoration: none; font-weight: 500; }
  .about-text a:hover { text-decoration: underline; }

  /* pub section */
  .pub-header {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 1rem;
  }

  .view-all {
    font-size: 0.8rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    display: flex; align-items: center; gap: 4px;
    cursor: pointer;
    background: none; border: none;
  }

  .view-all:hover { text-decoration: underline; }

  .pub-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.1rem 1.25rem;
    margin-bottom: 0.75rem;
    transition: box-shadow 0.2s, border-color 0.2s;
    cursor: pointer;
  }

  .pub-card:hover {
    box-shadow: var(--shadow);
    border-color: #d8d3cc;
  }

  .pub-title {
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.45;
    margin-bottom: 5px;
    color: var(--text-primary);
  }

  .pub-authors {
    font-size: 0.78rem;
    color: var(--accent);
    margin-bottom: 3px;
  }

  .pub-venue {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    font-style: italic;
    margin-bottom: 6px;
  }

  .pub-abstract {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pub-tags {
    display: flex; gap: 5px; flex-wrap: wrap; margin-top: 8px;
  }

  .tag {
    font-size: 0.68rem;
    font-family: 'DM Mono', monospace;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--accent-light);
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  /* photography grid */
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .photo-item {
    aspect-ratio: 3/2;
    border-radius: var(--radius);
    overflow: hidden;
    background: linear-gradient(145deg, #d4c5b0, #b8a990);
    position: relative;
    cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .photo-item:first-child {
    grid-column: span 2;
    aspect-ratio: 16/9;
  }

  .photo-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }

  .photo-item img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.4s;
  }

  .photo-item:hover img { transform: scale(1.03); }

  .photo-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, transparent 50%);
    opacity: 0; transition: opacity 0.25s;
  }

  .photo-item:hover .photo-overlay { opacity: 1; }

  .photo-caption {
    position: absolute; bottom: 10px; left: 12px;
    font-size: 0.72rem; color: #fff;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.04em;
    opacity: 0; transition: opacity 0.25s;
  }

  .photo-item:hover .photo-caption { opacity: 1; }

  /* photo placeholder colors */
  .photo-item:nth-child(1) { background: linear-gradient(145deg, #8ba8c4, #5a7fa8); }
  .photo-item:nth-child(2) { background: linear-gradient(145deg, #a8b89a, #7a9870); }
  .photo-item:nth-child(3) { background: linear-gradient(145deg, #c4a882, #a68860); }
  .photo-item:nth-child(4) { background: linear-gradient(145deg, #b4a0c0, #8a7099); }
  .photo-item:nth-child(5) { background: linear-gradient(145deg, #c4b090, #a08860); }

  .photo-placeholder-text {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 6px;
  }

  .photo-placeholder-text span {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* awards */
  .award-item {
    display: flex; gap: 1rem; align-items: flex-start;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border-light);
  }

  .award-item:last-child { border-bottom: none; }

  .award-year {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    min-width: 40px;
    padding-top: 2px;
  }

  .award-content { flex: 1; }

  .award-title {
    font-size: 0.88rem;
    font-weight: 500;
    margin-bottom: 2px;
  }

  .award-org {
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  /* cv section */
  .cv-section {
    display: flex; flex-direction: column; align-items: center;
    padding: 3rem 0;
    gap: 1rem;
  }

  .cv-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 24px;
    border-radius: 8px;
    border: 1px solid var(--accent);
    background: var(--accent);
    color: white;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
  }

  .cv-btn:hover { background: var(--accent-hover); border-color: var(--accent-hover); }

  /* animations */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* divider */
  .section-divider {
    height: 1px; background: var(--border);
    margin: 2rem 0;
  }

  /* responsive */
  @media (max-width: 720px) {
    .layout {
      grid-template-columns: 1fr;
      padding-left: 1rem; padding-right: 1rem;
    }
    .sidebar { position: static; }
    .profile-img-wrap { aspect-ratio: 1; max-width: 200px; margin: 0 auto 1.25rem; }
    .nav-links { display: none; }
    .photo-grid { grid-template-columns: 1fr 1fr; }
    .photo-item:first-child { grid-column: span 2; }
  }
</style>
</head>
